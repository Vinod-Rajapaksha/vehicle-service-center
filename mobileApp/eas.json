{
  "cli": {
    "version": ">= 18.9.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://service-center.up.railway.app/api/v1",
        "EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME": "dxrmwxtx0",
        "EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "service"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://service-center.up.railway.app/api/v1",
        "EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME": "dxrmwxtx0",
        "EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET": "service"
      }
    }
  },
  "submit": {
    "production": {}
  }
}